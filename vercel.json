{
  "version": 2,
  "builds": [
    { "src": "api/panews/calendar.py", "use": "@vercel/python" },
    { "src": "api/feed/rss.py", "use": "@vercel/python" },
    { "src": "api/soso/sectors.py", "use": "@vercel/python" },
    { "src": "api/admin.py", "use": "@vercel/python" },
    { "src": "api/okx/positions.py", "use": "@vercel/python" },
    { "src": "api/okx/ticker.py", "use": "@vercel/python" },
    { "src": "api/okx/account.py", "use": "@vercel/python" },
    { "src": "api/okx/order.py", "use": "@vercel/python" },
    { "src": "api/okx/close-position.py", "use": "@vercel/python" },
    { "src": "authorize.html", "use": "@vercel/static" },
    { "src": "trade.html", "use": "@vercel/static" },
    { "src": "AI深度分析金融界面 (11).html", "use": "@vercel/static" },
    { "src": "ai-watch.html", "use": "@vercel/static" },
    { "src": "ai-watch-loading.html", "use": "@vercel/static" },
    { "src": "ai-watch-report.html", "use": "@vercel/static" },
    { "src": "ai-watch-strategy.html", "use": "@vercel/static" },
    { "src": "code.html", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/authorize\\.html$", "dest": "/authorize.html" },
    { "src": "^/trade\\.html$", "dest": "/trade.html" },
    { "src": "^/AI深度分析金融界面\\s\\(11\\)\\.html$", "dest": "/AI深度分析金融界面 (11).html" },
    { "src": "^/ai-watch\\.html$", "dest": "/ai-watch.html" },
    { "src": "^/ai-watch-loading\\.html$", "dest": "/ai-watch-loading.html" },
    { "src": "^/ai-watch-report\\.html$", "dest": "/ai-watch-report.html" },
    { "src": "^/ai-watch-strategy\\.html$", "dest": "/ai-watch-strategy.html" },
    { "src": "^/code\\.html$", "dest": "/code.html" },
    { "src": "^/api/panews/calendar$", "dest": "/api/panews/calendar.py" },
    { "src": "^/api/feed/rss$", "dest": "/api/feed/rss.py" },
    { "src": "^/api/soso/sectors$", "dest": "/api/soso/sectors.py" },
    { "src": "^/api/admin(?:/.*)?$", "dest": "/api/admin.py" },
    { "src": "^/api/okx/positions$", "dest": "/api/okx/positions.py" },
    { "src": "^/api/okx/ticker$", "dest": "/api/okx/ticker.py" },
    { "src": "^/api/okx/account$", "dest": "/api/okx/account.py" },
    { "src": "^/api/okx/order$", "dest": "/api/okx/order.py" },
    { "src": "^/api/okx/close-position$", "dest": "/api/okx/close-position.py" },
    { "src": "^(.*)$", "dest": "/index.html" }
  ]
}
